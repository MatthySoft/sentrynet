<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <AssemblyName>SentryNet</AssemblyName>
    <RootNamespace>SentryNet</RootNamespace>
    <NoWarn>$(NoWarn);CA1416</NoWarn>

    <!-- Branding -->
    <Product>SentryNet</Product>
    <AssemblyTitle>SentryNet</AssemblyTitle>
    <Company>MatthySoft</Company>
    <Authors>MatthySoft</Authors>
    <Copyright>© MatthySoft</Copyright>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Diagnostics.Tracing.TraceEvent" Version="3.1.16" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\worldmap.txt" />
    <Resource Include="Assets\sentrynet_logo_small.png" />
    <Resource Include="Assets\sentrynet_logo_banner.png" />
    <Resource Include="Assets\sentrynet_logo_icon.png" />
  </ItemGroup>

</Project>
